{
  "manifest_version": 3,
  "name": "AI Quota Cookie Bridge",
  "version": "1.0.0",
  "description": "将浏览器中的 Kimi / MiMo 认证 Cookie 安全地转发给本地 VSCode AI Quota Dashboard 扩展",
  "permissions": [
    "cookies",
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://*.kimi.com/",
    "https://*.xiaomimimo.com/",
    "https://open.bigmodel.cn/",
    "http://127.0.0.1:*/"
  ],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Quota Dashboard"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Q"
      }
    },
    "open-dashboard": {
      "suggested_key": {
        "default": "Alt+Shift+Q"
      },
      "description": "打开 AI Quota Dashboard"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
