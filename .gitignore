# ============================================
# AI Quota Dashboard — Git Ignore
# ============================================

# === VSCode Extension ===
vscode/out/
vscode/dist/
vscode/node_modules/
vscode/.vscode-test/
vscode/coverage/
vscode/.eslintcache

# === Browser Extension ===
# (浏览器扩展是纯 JS，无 node_modules，但保留以备将来引入构建工具)
browser/node_modules/
browser/dist/
browser/**/*.map

# === Package Artifacts ===
*.vsix
ai-quota-cookie-bridge-*.zip
build/

# === OS Generated ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# === IDE / Editor ===
.history/
.idea/
*.swp
*.swo
*~

# === Logs ===
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === Environment / Secrets ===
.env
.env.local
.env.*.local

# === Temporary Files ===
*.tmp
*.temp
.cache/
tmp/

# === Runtime ===
# Cookie Bridge 临时端口文件
.ai-quota-bridge-port

# === AI Assistant Context ===
# (可能包含敏感 API 详情或个人配置)
AGENTS.md
opencode.json

# === VSCode Workspace Settings ===
# (用户级个人设置，不应提交)
.vscode/settings.json
