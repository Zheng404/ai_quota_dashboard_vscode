{
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-quota-dashboard@zheng404.github.io",
      "strict_min_version": "116.0"
    }
  },
  "name": "AI Quota Cookie Bridge",
  "version": "1.0.0",
  "description": "将浏览器中的 Kimi / MiMo 认证 Cookie 安全地转发给本地 VSCode AI Quota Dashboard 扩展",
  "permissions": [
    "cookies",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.kimi.com/",
    "https://*.xiaomimimo.com/"
  ],
  "background": {
    "scripts": ["scripts/background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Quota Dashboard"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Q"
      }
    },
    "open-dashboard": {
      "suggested_key": {
        "default": "Alt+Shift+Q"
      },
      "description": "打开 AI Quota Dashboard"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
